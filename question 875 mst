class Solution {
public:
    int minEatingSpeed(vector<int>& piles, int h) {
        int l=1,r=*max_element(piles.begin(),piles.end());
        int ans=r;
        while(l<=r){
            int mid=l+(r-l+1)/2;
            long long hour=0;
            for(int p:piles){
                hour+=(p+mid-1)/mid;
            }
            if(hour<=h){
                ans=mid;
                r=mid-1;
            }
            else l=mid+1;
        }
        return ans;
    }
};
