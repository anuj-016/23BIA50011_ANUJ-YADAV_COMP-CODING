#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        int n;
        cin >> n;

        vector<int> a(n);
        for (int i = 0; i < n; i++) cin >> a[i];

        vector<bool> good(n + 1, false);

        // generate all subarray sums of length >= 2
        for (int i = 0; i < n; i++) {
            int sum = a[i];
            for (int j = i + 1; j < n; j++) {
                sum += a[j];
                if (sum <= n) {
                    good[sum] = true;
                }
            }
        }

        int count = 0;
        for (int x : a) {
            if (x <= n && good[x]) count++;
        }

        cout << count << "\n";
    }

    return 0;
}
